DJANGO_SECRET_KEY=replace-with-strong-secret
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/quillmind_dev?sslmode=require
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
OPENAI_API_KEY=sk-replace-with-openai-key
LLM_OPENAI_MODEL=gpt-4o
STYLE_EMBEDDING_MODEL=text-embedding-3-small
STYLE_EMBEDDING_TIMEOUT_SECONDS=12
STYLE_SAMPLE_MAX_FILE_BYTES=2097152
LLM_PROVIDER_ORDER=openai
LLM_RATE_LIMIT_PER_MINUTE=20
DOCUMENT_MODEL_VERSION=v1.0.0
DOCUMENT_MODEL_PATH=backend/models/document_review/v1.0.0/model.onnx
DOCUMENT_REVIEW_MAX_TOKENS=512
DOCUMENT_REVIEW_CHUNK_STRIDE=64
DOCUMENT_REVIEW_SCORE_THRESHOLD=0.5

